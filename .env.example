# ===================================
# Intervals.icu API (required for STDIO mode)
# ===================================
INTERVALS_ICU_BASE_URL="https://intervals.icu"
INTERVALS_ICU_ATHLETE_ID="<your-athlete-id>"
INTERVALS_ICU_API_KEY="<your-api-key>"

# ===================================
# MCP Transport Configuration
# ===================================
# Transport mode: "stdio" (default) or "http"
# - stdio: for local MCP clients (VS Code, Claude Desktop)
# - http: for remote MCP clients or running as a service
MCP_TRANSPORT=stdio

# HTTP mode settings (used only when MCP_TRANSPORT=http)
MCP_HTTP_ADDRESS=127.0.0.1:3000
MAX_HTTP_BODY_SIZE=4194304  # 4MB (security limit)
REQUEST_TIMEOUT_SECONDS=30  # Max time per request
IDLE_TIMEOUT_SECONDS=60     # TCP keepalive for idle connections

# ===================================
# JWT Authentication (required for HTTP mode)
# ===================================
# Generate with: openssl rand -hex 32
# ⚠️ NEVER commit these to git!
JWT_SECRET="<64 hex chars>"
JWT_ENCRYPTION_KEY="<64 hex chars>"
JWT_TTL_SECONDS=86400  # 24 hours (max: 604800 = 7 days)

# ===================================
# Optional OpenAPI source override
# ===================================
# INTERVALS_ICU_OPENAPI_SPEC="https://intervals.icu/api/v1/docs"
INTERVALS_ICU_SPEC_REFRESH_SECS=300

# ===================================
# Logging
# ===================================
# Standard RUST_LOG environment variable
# Examples: info, debug, trace, warn, error
# RUST_LOG="info"

# ===================================
# Example client variables
# ===================================
INTERVALS_ICU_ACTIVITY_ID="<activity-id>"
INTERVALS_ICU_OUTPUT="./downloads"
INTERVALS_ICU_LIMIT=20
