# Sample environment variables for rusty-intervals-mcp

# Intervals.icu API
INTERVALS_ICU_BASE_URL="https://intervals.icu"
INTERVALS_ICU_ATHLETE_ID="<your-athlete-id>"
INTERVALS_ICU_API_KEY="<your-api-key>"

# Optional OpenAPI source override (HTTP URL or local JSON path)
# INTERVALS_ICU_OPENAPI_SPEC="https://intervals.icu/api/v1/docs"

# Optional registry refresh interval in seconds (default: 300)
INTERVALS_ICU_SPEC_REFRESH_SECS=300

# Optional tag scoping (set one or neither):
# INTERVALS_INCLUDE_TAGS="Wellness,Activities"
# INTERVALS_EXCLUDE_TAGS="Gear"
#
# Available tags (use exact spelling from the OpenAPI spec).  Common groups:
#   Activities, Wellness, Events, Gear, Sports, Athletes, Library
# Additional sections in the spec you might see:
#   Shared Events, Chats, Weather, Routes, Custom Items, o-auth-server-controller
# Feel free to mix comma-separated values (no spaces) when using INCLUDE.

# Logging level (supported: info, warn, debug, trace)
# Uses standard RUST_LOG environment variable
RUST_LOG="info"

# HTTP server configuration (used by the example / http binary)
ADDRESS="0.0.0.0:8080"
MAX_HTTP_BODY_SIZE=52428800

# Example client vars (used in examples)
INTERVALS_ICU_ACTIVITY_ID="<activity-id>"
INTERVALS_ICU_OUTPUT="./downloads"
INTERVALS_ICU_LIMIT=20
